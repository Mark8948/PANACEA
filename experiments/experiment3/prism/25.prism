global N_13 : [0..2];
global N_102 : [1..2];
global N_103 : [1..2];
global N_106 : [1..2];
global N_105 : [1..2];
global N_104 : [1..2];
global N_101 : [1..2];

module attacker

	a5 : bool;
	a6 : bool;
	a7 : bool;
	a8 : bool;
	a9 : bool;
	a10 : bool;
	a11 : bool;
	a12 : bool;
	a13 : bool;
	a14 : bool;
	a15 : bool;
	a16 : bool;
	a17 : bool;
	a18 : bool;
	a19 : bool;

	[a5] sched=1 & !root=1 & root=0 & !a5 & (N_5=1) -> (root'=1) & (a5'=true) & (sched'=2);
	[a6] sched=1 & !root=1 & root=0 & !a6 & (N_6=1) -> (root'=1) & (a6'=true) & (sched'=2);
