	[a11] sched=1 & !root=1 & N_6=0 & !a11 & (N_11=1) -> (N_6'=1) & (a11'=true) & (sched'=2);
	[a12] sched=1 & !root=1 & N_6=0 & !a12 & (N_12=1) -> (N_6'=1) & (a12'=true) & (sched'=2);
	[a13] sched=1 & !root=1 & N_7=0 & !a13 & (N_13=1) -> (N_7'=1) & (a13'=true) & (sched'=2);
	[a14] sched=1 & !root=1 & N_8=0 & !a14 & (N_101=1) -> (N_8'=1) & (a14'=true) & (sched'=2);
	[a15] sched=1 & !root=1 & N_9=0 & !a15 & (N_102=1) -> (N_9'=1) & (a15'=true) & (sched'=2);
	[a16] sched=1 & !root=1 & N_10=0 & !a16 & (N_103=1) -> (N_10'=1) & (a16'=true) & (sched'=2);
	[a17] sched=1 & !root=1 & N_11=0 & !a17 & (N_104=1) -> (N_11'=1) & (a17'=true) & (sched'=2);
	[a18] sched=1 & !root=1 & N_12=0 & !a18 & (N_105=1) -> (N_12'=1) & (a18'=true) & (sched'=2);
	[a19] sched=1 & !root=1 & N_13=0 & !a19 & (N_106=1) -> (N_13'=1) & (a19'=true) & (sched'=2);

endmodule

module defender


	[c5] sched=2 & !root=1 & !N_5=2 -> (N_5'=2) & (sched'=1);
	[c6] sched=2 & !root=1 & !N_6=2 -> (N_6'=2) & (sched'=1);
	[c7] sched=2 & !root=1 & !N_7=2 -> (N_7'=2) & (sched'=1);
	[c8] sched=2 & !root=1 & !N_8=2 -> (N_8'=2) & (sched'=1);
	[c9] sched=2 & !root=1 & !N_9=2 -> (N_9'=2) & (sched'=1);
	[c10] sched=2 & !root=1 & !N_10=2 -> (N_10'=2) & (sched'=1);
	[c11] sched=2 & !root=1 & !N_11=2 -> (N_11'=2) & (sched'=1);
	[c12] sched=2 & !root=1 & !N_12=2 -> (N_12'=2) & (sched'=1);
	[c13] sched=2 & !root=1 & !N_13=2 -> (N_13'=2) & (sched'=1);

endmodule

