smg

player attacker
	attacker,
	[a5], [a6], [a7], [a8], [a9], [a10], [a11], [a12], [a13], [a14], [a15], [a16], [a17], [a18], [a19]
endplayer
player defender
	defender,
	[c5], [c6], [c7], [c8], [c9], [c10], [c11], [c12], [c13]
endplayer

global sched : [1..2];

global root : [0..1];
label "terminate" = root=1;

global N_9 : [0..2];
global N_12 : [0..2];
global N_11 : [0..2];
global N_7 : [0..2];
global N_10 : [0..2];
global N_8 : [0..2];
