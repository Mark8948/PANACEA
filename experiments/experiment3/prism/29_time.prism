smg

player attacker
	attacker, [wait1],
	[starta1], [enda1], [starta3], [enda3], [starta5], [enda5], [starta6], [enda6], [starta7], [enda7], [starta8], [enda8], [starta9], [enda9], [starta10], [enda10], [starta11], [enda11], [starta12], [enda12], [starta13], [enda13], [starta14], [enda14], [starta15], [enda15], [starta16], [enda16], [starta17], [enda17], [starta18], [enda18], [starta19], [enda19]
endplayer
player defender
	defender, [wait2],
	[startc1], [endc1], [startc2], [endc2], [startc4], [endc4], [startc5], [endc5], [startc6], [endc6], [startc7], [endc7], [startc8], [endc8], [startc9], [endc9], [startc10], [endc10], [startc11], [endc11], [startc12], [endc12], [startc13], [endc13]
endplayer

global sched : [1..2];

global root : [0..1];
label "terminate" = root=1;

global N_6 : [0..2];
global N_2 : [0..2];
