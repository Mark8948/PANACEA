	time1 : [-1..3];
	[wait1] sched=1 & time1>0 -> (sched'=2) & (time1'=time1-1);

	[starta1] sched=1 & time1<0 & !progressa1 & !root=1 & root=0 & (N_1=1 & N_2=1) -> (sched'=2) & (time1'=2) & (progressa1'=true);
	[enda1] sched=1 & time1=0 & progressa1 & !root=1 & root=0 & (N_1=1 & N_2=1) -> (time1'=time1-1) & (progressa1'=false) & (root'=1);
	[faila1] sched=1 & time1=0 & progressa1 & !root=1 & (!root=0  | !N_1=1 | !N_2=1) -> (time1'=time1-1) & (progressa1'=false);

	[starta3] sched=1 & time1<0 & !progressa3 & !root=1 & N_2=0 & (N_4=1) -> (sched'=2) & (time1'=1) & (progressa3'=true);
	[enda3] sched=1 & time1=0 & progressa3 & !root=1 & N_2=0 & (N_4=1) -> (time1'=time1-1) & (progressa3'=false) & (N_2'=1);
